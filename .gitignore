# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Django
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
*.log

# Environment
.env
.env.local

# Node / Vite
node_modules/
frontend/dist/
# web/static/dist/ is tracked on purpose: the CloudLinux host has no Node, so the
# built bundle (including its .vite/manifest.json) ships in the repo for
# `collectstatic` to gather. Rebuilt on every `cz bump` via the make_requirements
# pre-bump hook. Vite's own dep cache lives under node_modules/.vite, already ignored.

# Tooling
.pytest_cache/
.ruff_cache/
.coverage
cov.xml
htmlcov/

# Editors / OS
.idea/
.DS_Store
Thumbs.db

# .vscode/ is tracked on purpose — launch/tasks/extensions are shared project config.
# Personal overrides belong in .vscode/settings.local.json, which is not.
.vscode/*.local.json

# Scratch
files.zip
