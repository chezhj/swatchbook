# Copy to .env and fill in. Never commit .env.

# Required in production. Generate with:
#   poetry run python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=dev-insecure-key-change-me

# 1/true in development, 0/false in production.
DJANGO_DEBUG=1

# Comma-separated. Required when DEBUG is off.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Which settings module to load. Overridden by manage.py default in dev.
DJANGO_SETTINGS_MODULE=config.settings.dev
